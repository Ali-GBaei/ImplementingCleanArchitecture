@model StoreWebsite.Web.Models.Products.ProductFormViewModel
@{
    ViewData["Title"] = "Delete Product";
}

<div class="card border-danger shadow-sm">
    <div class="card-body">
        <h3 class="text-danger">Delete Product</h3>
        <p>Are you sure you want to delete <strong>@Model.Name</strong>?</p>
        <ul class="list-group mb-3">
            <li class="list-group-item"><strong>Description:</strong> @Model.Description</li>
            <li class="list-group-item"><strong>Price:</strong> @Model.Price.ToString("C")</li>
            <li class="list-group-item"><strong>Stock:</strong> @Model.StockQuantity</li>
        </ul>

        <form asp-action="ConfirmDelete" method="post">
            <input type="hidden" name="id" value="@Model.Id" />
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-danger">Delete</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>
